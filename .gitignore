# Ansible artifacts
*.retry
*.log
*.pyc
__pycache__/
*.swp
*.bak
*~
.ansible/
.ansible_tmp/

# Vault secrets — never commit unencrypted secrets
*vault*.yml
*vault*.yaml
*secrets*.yml
*secrets*.yaml

# Local inventory overrides and dynamic inventory caches
inventory/*.local
inventory/.cache/
*.local.ini
*.local.yml

# Editor / OS noise
.vscode/
.idea/
.DS_Store
Thumbs.db

# Python (only relevant if you add Python tooling)
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
.env
.envrc
